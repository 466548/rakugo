# 寄席コンシェルジュ「前座さん」 環境変数サンプル
# このファイルを .env.local にコピーして値を設定してください（.env.local は gitignore 済み）。
#   cp env.example .env.local

# --- Gemini / ADK ---
# Google AI Studio (https://aistudio.google.com) で無料キーを取得して設定。
# 未設定でも決定的なモック動作で全画面デモできます（matching/parse がルールベースになる）。
GEMINI_API_KEY=

# 使用モデル（既定: gemini-flash-latest）
RAKUGO_GEMINI_MODEL=gemini-flash-latest

# AI を強制的にモックにしたい場合は true（キーがあっても使わない）
RAKUGO_FORCE_MOCK=false

# --- データストア ---
# local: ローカルJSONファイル（既定 / GCP不要） | firestore: 本番（Stretch）
RAKUGO_DATA_BACKEND=local
# local バックエンドのデータ保存先（リポジトリ直下 .localdata/ 配下）
RAKUGO_LOCAL_DATA_DIR=.localdata

# --- GCP（本番デプロイ時のみ。ローカル先行では不要）---
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=asia-northeast1
